# ─── Razorpay Lambda — Environment Variables ────────────────────────────────
# Copy this file as reference. Set these in:
#   AWS Console → Lambda → Configuration → Environment variables
# OR via CLI:
#   aws lambda update-function-configuration --function-name vybn-razorpay-lambda \
#     --environment "Variables={RAZORPAY_KEY_ID=...,RAZORPAY_KEY_SECRET=...}"
#
# ⚠️  NEVER commit actual key values to source control.
# ────────────────────────────────────────────────────────────────────────────

# Your Razorpay API Key ID (provided by Razorpay)
RAZORPAY_KEY_ID=YOUR_KEY_ID_HERE

# Your Razorpay Secret Key (provided by Razorpay)
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

# ─── Deployment Credentials (Optional) ──────────────────────────────────────
# Required ONLY when running the deploy.sh script for the first-time creation.
# Existing updates do not require this.
LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/service-role/your-lambda-execution-role
